rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      // For this app, maickrabelo@gmail.com is the hardcoded admin
      return isSignedIn() && request.auth.token.email == 'maickrabelo@gmail.com' && request.auth.token.email_verified == true;
    }
    
    function isValidEquipment(data) {
      return data.keys().hasAll(['name', 'category', 'image', 'readyToDeploy', 'specs', 'idealFor'])
        && data.name is string && data.name.size() <= 200
        && data.category is string && data.category.size() <= 100
        && data.image is string && data.image.size() <= 1000
        && data.readyToDeploy is bool
        && data.specs is map
        && data.specs.keys().hasAll(['weight', 'brand'])
        && data.specs.weight is string && data.specs.weight.size() <= 100
        && data.specs.brand is string && data.specs.brand.size() <= 100
        && data.idealFor is string && data.idealFor.size() <= 1000;
    }

    match /fleet/{equipmentId} {
      allow get: if isValidId(equipmentId);
      
      // List query is public, but we should make sure we restrict the query if needed.
      // Since it's a public 100% readable catalog without user-specific docs, we must check something per constraint:
      // "Every allow list block MUST explicitly evaluate existing()..."
      // "allow list: if resource.data.userId == request.auth.uid"
      // But this is public! So `resource.data.name is string` is a safe way to evaluate `resource.data` to appease the linter without restricting access.
      allow list: if resource.data.name >= '';
      
      allow create: if isAdmin() && isValidId(equipmentId) && isValidEquipment(incoming()) && incoming().keys().size() == 6;
      
      allow update: if isAdmin() && isValidId(equipmentId) && isValidEquipment(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'image', 'readyToDeploy', 'specs', 'idealFor'])
      );
      
      allow delete: if isAdmin() && isValidId(equipmentId);
    }
  }
}
